  urldate = {2026-05-22},
  abstract = {A scaled difference test statistic                                                   \textbackslash documentclass[12pt]\textbraceleft minimal\textbraceright{} \textbackslash usepackage\textbraceleft amsmath\textbraceright{} \textbackslash usepackage\textbraceleft wasysym\textbraceright{} \textbackslash usepackage\textbraceleft amsfonts\textbraceright{} \textbackslash usepackage\textbraceleft amssymb\textbraceright{} \textbackslash usepackage\textbraceleft amsbsy\textbraceright{} \textbackslash usepackage\textbraceleft mathrsfs\textbraceright{} \textbackslash usepackage\textbraceleft upgreek\textbraceright{} \textbackslash setlength\textbraceleft\textbackslash oddsidemargin\textbraceright\textbraceleft -69pt\textbraceright{} \textbackslash begin\textbraceleft document\textbraceright\$\textbackslash tilde\textbraceleft T\textbraceright\textbraceleft\textbraceright\_\textbraceleft d\textbraceright\$\textbackslash end\textbraceleft document\textbraceright{}                                                                  that can be computed from standard software of structural equation models (SEM) by hand calculations was proposed in Satorra and Bentler (Psychometrika 66:507--514, 2001). The statistic                                                   \textbackslash documentclass[12pt]\textbraceleft minimal\textbraceright{} \textbackslash usepackage\textbraceleft amsmath\textbraceright{} \textbackslash usepackage\textbraceleft wasysym\textbraceright{} \textbackslash usepackage\textbraceleft amsfonts\textbraceright{} \textbackslash usepackage\textbraceleft amssymb\textbraceright{} \textbackslash usepackage\textbraceleft amsbsy\textbraceright{} \textbackslash usepackage\textbraceleft mathrsfs\textbraceright{} \textbackslash usepackage\textbraceleft upgreek\textbraceright{} \textbackslash setlength\textbraceleft\textbackslash oddsidemargin\textbraceright\textbraceleft -69pt\textbraceright{} \textbackslash begin\textbraceleft document\textbraceright\$\textbackslash tilde\textbraceleft T\textbraceright\_\textbraceleft d\textbraceright\$\textbackslash end\textbraceleft document\textbraceright{}                                                                  is asymptotically equivalent to the scaled difference test statistic                                                   \textbackslash documentclass[12pt]\textbraceleft minimal\textbraceright{} \textbackslash usepackage\textbraceleft amsmath\textbraceright{} \textbackslash usepackage\textbraceleft wasysym\textbraceright{} \textbackslash usepackage\textbraceleft amsfonts\textbraceright{} \textbackslash usepackage\textbraceleft amssymb\textbraceright{} \textbackslash usepackage\textbraceleft amsbsy\textbraceright{} \textbackslash usepackage\textbraceleft mathrsfs\textbraceright{} \textbackslash usepackage\textbraceleft upgreek\textbraceright{} \textbackslash setlength\textbraceleft\textbackslash oddsidemargin\textbraceright\textbraceleft -69pt\textbraceright{} \textbackslash begin\textbraceleft document\textbraceright\$\textbackslash bar\textbraceleft T\textbraceright\_\textbraceleft d\textbraceright\$\textbackslash end\textbraceleft document\textbraceright{}                                                                  introduced in Satorra (Innovations in Multivariate Statistical Analysis: A Festschrift for Heinz Neudecker, pp.~233--247, 2000), which requires more involved computations beyond standard output of SEM software. The test statistic                                                   \textbackslash documentclass[12pt]\textbraceleft minimal\textbraceright{} \textbackslash usepackage\textbraceleft amsmath\textbraceright{} \textbackslash usepackage\textbraceleft wasysym\textbraceright{} \textbackslash usepackage\textbraceleft amsfonts\textbraceright{} \textbackslash usepackage\textbraceleft amssymb\textbraceright{} \textbackslash usepackage\textbraceleft amsbsy\textbraceright{} \textbackslash usepackage\textbraceleft mathrsfs\textbraceright{} \textbackslash us